{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "S3": {
    "Region": "us-east-1",
    "AccessKey": "admin",
    "SecretKey": "password123",
    "BucketName": "user-001",
    "Endpoint": "https://localhost:9000",
    "ForcePathStyle": true
  },
  "Postgres": {
    "Host": "localhost",
    "Port": 5432,
    "Database": "db",
    "User": "user",
    "Password": "password123"
  },
  "Upload": {
    "UploadExpiration": "00:10:00",
    "DownloadExpiration": "00:10:00",
    "MaxPartsCount": 1000,
    "MaxFileSizeGiB": 100,
    "SingleUploadMaxSizeMiB": 64,
    "DefaultPartSizeMiB": 32,
    "MinPartSizeMiB": 5,
    "MaxPartSizeMiB": 128
  }
}
